# =============================================================
# NETLIFY ENVIRONMENT VARIABLES
# Встановити в: Netlify Dashboard → Site → Environment Variables
# =============================================================

# ── БАЗА ДАНИХ (Turso — хмарний SQLite) ──────────────────────
# Отримати на: https://turso.tech → Dashboard → ваша БД
TURSO_DATABASE_URL="libsql://your-db-name.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token-here"

# DATABASE_URL для Prisma CLI (db push під час білду)
# Формат: libsql://host?authToken=token
DATABASE_URL="libsql://your-db-name.turso.io?authToken=your-token"

# ── JWT ───────────────────────────────────────────────────────
# Згенеруйте: https://generate-secret.vercel.app/32
JWT_SECRET="your-super-secret-random-string-minimum-32-chars"
JWT_EXPIRES_IN="7d"

# ── CORS (ваш Netlify сайт) ───────────────────────────────────
FRONTEND_URL="https://zippy-dieffenbachia-cb13e3.netlify.app"
ADMIN_URL="https://zippy-dieffenbachia-cb13e3.netlify.app"

# ── FRONTEND API URL ──────────────────────────────────────────
# Той самий сайт (бекенд живе там же як Netlify Function)
NEXT_PUBLIC_API_URL="https://zippy-dieffenbachia-cb13e3.netlify.app/api"

# ── CLOUDINARY (фото тварин і грумерів) ──────────────────────
# Отримати на: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ── EMAIL (опційно, для контактної форми) ─────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-google-app-password"
SMTP_FROM="noreply@glanzgroom.ua"
CONTACT_EMAIL="hello@glanzgroom.ua"


# =============================================================
# ЛОКАЛЬНА РОЗРОБКА
# Створити: backend/.env
# =============================================================
# DATABASE_URL="file:./dev.db"
# JWT_SECRET="local-dev-secret"
# JWT_EXPIRES_IN="7d"
# PORT=3001
# FRONTEND_URL="http://localhost:3000"
# ADMIN_URL="http://localhost:3002"
