# Цей файл є прикладом. Створіть реальні .env файли в папках backend, frontend та admin на сервері.

# ==========================================
# === BACKEND (шлях: backend/.env)       ===
# ==========================================
# Файл бази даних (залишаємо як є, або вказуємо шлях до продакшен бази)
DATABASE_URL="file:./dev.db"

# Секрет для JWT токенів (згенеруйте довгий випадковий рядок)
JWT_SECRET="YOUR_SUPER_SECURE_RANDOM_STRING_HERE"
JWT_EXPIRES_IN="7d"

# Порт для бекенду (збігається з PM2)
PORT=3001

# CORS: Дозволені домени (замініть на ваші продакшн домени)
FRONTEND_URL="https://YOUR_DOMAIN.com"
ADMIN_URL="https://admin.YOUR_DOMAIN.com"

# Email (необов'язково, для контактної форми)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="ваша_пошта@gmail.com"
SMTP_PASS="пароль_додатку_google"
SMTP_FROM="noreply@YOUR_DOMAIN.com"
CONTACT_EMAIL="hello@YOUR_DOMAIN.com"


# ==========================================
# === FRONTEND (шлях: frontend/.env.local) ===
# ==========================================
# URL вашого бекенду
NEXT_PUBLIC_API_URL="https://api.YOUR_DOMAIN.com/api"


# ==========================================
# === ADMIN (шлях: admin/.env.local)     ===
# ==========================================
# URL вашого бекенду
NEXT_PUBLIC_API_URL="https://api.YOUR_DOMAIN.com/api"
